# Copy this file to .env for local reference. Do not commit the copied .env file.
# Spring Boot does not load .env automatically; export these variables in your shell or IDE run configuration.

DB_URL=jdbc:mysql://localhost:3306/smart_agri?createDatabaseIfNotExist=true
DB_USERNAME=smartagri_user
DB_PASSWORD=replace-with-your-local-mysql-password
APP_API_KEY=replace-with-a-long-random-value
OPENWEATHER_API_KEY=
OPENAI_API_KEY=
OPENAI_ENABLED=false
